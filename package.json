  "files": [
    "src"
  ],
  "dependencies": {
    "@gitbeaker/rest": "^43.8.0",
    "@octokit/rest": "^22.0.1",
    "azure-devops-node-api": "^15.1.2",
    "bitbucket": "^2.12.0",
    "commander": "^12.1.0",
    "ink": "^5.0.1",
    "minimatch": "^10.1.1",
    "open": "^10.1.0",
    "posthog-node": "^5.28.5",
    "react": "^18.3.1",
    "smol-toml": "^1.6.1"
