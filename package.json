{
  "name": "codeant-cli",
  "version": "0.4.8",
  "description": "Code review CLI tool",
  "type": "module",
  "bin": {
    "codeant": "./src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "cli",
    "code-review",
    "secrets"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "main": "./src/reviewHeadless.js",
